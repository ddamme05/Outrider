# Build the dashboard SPA, then serve it (and proxy /api) via Caddy.
FROM node:24.18.0-slim AS build
WORKDIR /dashboard
COPY dashboard/package.json dashboard/package-lock.json ./
RUN npm ci
COPY dashboard/ ./
# Empty API base => the SPA issues same-origin /api/* requests, which Caddy proxies
# to the app. (src/api/client.ts reads VITE_API_BASE_URL, default "".)
RUN VITE_API_BASE_URL="" npm run build

FROM caddy:2.11.4
COPY --from=build /dashboard/dist /srv/dashboard
COPY deploy/Caddyfile /etc/caddy/Caddyfile
