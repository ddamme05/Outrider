# {$DEMO_DOMAIN}: set to your domain (e.g. demo.example.com) for automatic HTTPS,
# or to ":80" to serve plain HTTP on the droplet's IP (no certificate).
{$DEMO_DOMAIN} {
	encode gzip

	# Read API + liveness probe -> the keyless FastAPI app (internal network only).
	handle /api/* {
		reverse_proxy app:8000
	}
	handle /health {
		reverse_proxy app:8000
	}
	# The backend-rendered privacy page (DECISIONS #013/#015/#016). The `*` also
	# covers a trailing slash (/privacy/), which the exact matcher would otherwise
	# leak to the SPA catch-all. Every non-/api backend route needs its own handle
	# here — the catch-all below silently swallows anything unproxied
	# (tests/unit/test_demo_caddyfile_parity.py is the drift guard).
	handle /privacy* {
		reverse_proxy app:8000
	}

	# Everything else -> the dashboard SPA, with history-API fallback to index.html.
	handle {
		root * /srv/dashboard
		try_files {path} /index.html
		file_server
	}
}
