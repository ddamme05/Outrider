# Keyless demo deploy — copy to `.env` and fill in. NO live LLM/GitHub/Slack keys
# belong on this box (DEMO_MODE never reads them).

# Strong random password for the demo Postgres (internal-only; never exposed). It is
# interpolated into DATABASE_URL, so it must be URL-safe — generate one with
#   python3 -c 'import secrets; print(secrets.token_urlsafe(24))'
# A password containing @ : / # or % would corrupt the connection URL.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# The dashboard read token. It only gates read-only access to seeded data, so it is
# effectively PUBLIC for the demo — share it with viewers (or pre-fill it; see README).
# Left as `change-me` ON PURPOSE: the app's placeholder denylist rejects it at startup
# (DashboardSettings._reject... in api/dashboard/config.py), so a verbatim copy fails
# loud instead of booting with a guessable token. Replace it before launch.
OUTRIDER_ADMIN_API_KEY=change-me

# Your domain (DNS A record -> the droplet IP) for automatic HTTPS via Caddy.
# Use ":80" instead to serve plain HTTP on the droplet IP (no certificate).
DEMO_DOMAIN=demo.example.com
