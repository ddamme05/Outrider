                {
                  "type": "null"
                }
              ],
              "title": "X-Hub-Signature-256"
            }
          },
          {
            "name": "x-github-event",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Github-Event"
            }
          },
          {
            "name": "x-github-delivery",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Github-Delivery"
            }
          }
