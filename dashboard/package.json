{
  "name": "outrider-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Outrider operator console — React 19 + Vite SPA over the read-only dashboard API.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "gen:types": "openapi-typescript openapi.json -o src/api/schema.d.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "5.100.14",
    "openapi-fetch": "0.17.0",
    "openapi-react-query": "0.5.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-router": "^7.17.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "msw": "2.14.6",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
