# Database
# Decision #001: both URLs use psycopg3 in V1.
DATABASE_URL=postgresql+psycopg://outrider:outrider@localhost:5432/outrider
CHECKPOINT_DATABASE_URL=postgresql+psycopg://outrider:outrider@localhost:5432/outrider

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=replace-me

# LLM provider
ANTHROPIC_API_KEY=replace-me

# Dashboard/API auth
ADMIN_API_KEY=replace-me

# Review limits
PER_REVIEW_BUDGET_USD=0.30
MAX_DIFF_LINES_DEEP=500
MAX_DIFF_LINES_STANDARD=1000
MAX_CHANGED_FILES=30
MAX_TRACE_DEPTH=2
MAX_FINDINGS_PER_REVIEW=25

# HITL and sweeps
HITL_TIMEOUT_MINUTES=30
HITL_TIMEOUT_ACTION=expire_only
REVIEW_SWEEP_TIMEOUT_MINUTES=15

# Logging
LOG_LEVEL=info
