# ── Postgres (consumed by docker-compose.yml) ───────────────────────────────
# Compose's :? syntax fails fast if any of these are missing — Postgres will
# not start with default credentials. Generate a strong password once:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Then paste the same value into POSTGRES_PASSWORD AND into the URLs below.
#
# COUPLING WARNING (.env files do not interpolate values, so this is manual):
# If you change POSTGRES_PORT (e.g., to 5433 because 5432 is taken locally),
# you MUST also update the port number in BOTH URL lines below. Otherwise
# Postgres binds to the new port while the application connects to 5432 —
# silent connection failure, or worse, a connection to a different DB if
# something else is listening on 5432. The same coupling applies to
# POSTGRES_USER and POSTGRES_PASSWORD (must match the credentials embedded
# in both URLs). A future settings.py can derive the URLs from parts
# programmatically; today the .env stays the single source of truth.
POSTGRES_USER=outrider
POSTGRES_PASSWORD=replace-with-token_urlsafe-32-output
POSTGRES_DB=outrider
POSTGRES_PORT=5432

# ── Application database URLs ───────────────────────────────────────────────
# Decision #001: both URLs use psycopg3 in V1. They remain separate env vars
# so they can point at different databases later (e.g., a separate checkpoint
# store) without a code change.
#
# Three values below MUST match the Postgres section above:
#   - user                  → POSTGRES_USER         (currently "outrider")
#   - password              → POSTGRES_PASSWORD     (replace-with-...)
#   - port (after the host) → POSTGRES_PORT         (currently 5432)
DATABASE_URL=postgresql+psycopg://outrider:replace-with-token_urlsafe-32-output@127.0.0.1:5432/outrider
# CHECKPOINT_DATABASE_URL is OPTIONAL (DECISIONS.md#068): the checkpointer uses it when
# set, else falls back to DATABASE_URL. Leave it unset for a single-DB deploy. To split
# checkpoint storage onto a separate database, set it (postgresql+psycopg:// scheme) — and
# apply retention/backup/deletion controls to BOTH databases (the checkpoint store holds
# content-bearing ReviewState with no purge/scrub in V1; see FUP-095). An explicitly-set
# but empty or wrong-scheme value fails startup.
CHECKPOINT_DATABASE_URL=postgresql+psycopg://outrider:replace-with-token_urlsafe-32-output@127.0.0.1:5432/outrider

# ── Integration-test Postgres (consumed by docker-compose.yml + tests) ──────
# Separate Postgres container on port 5433 with tmpfs data — every container
# restart wipes state. The integration-test fixture connects here exclusively
# so a buggy test cannot reach the dev `outrider` DB above. See
# tests/integration/conftest.py for the URL-pattern fail-loud guard.
#
# Use a DIFFERENT password from POSTGRES_PASSWORD above. The two containers
# are separate processes; sharing a password gives no isolation benefit.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# COUPLING WARNING: same as the dev block above — TEST_DATABASE_URL hard-codes
# the password and port, so changes to TEST_POSTGRES_PASSWORD or TEST_POSTGRES_PORT
# require updating the URL line in this file too.
TEST_POSTGRES_USER=outrider
TEST_POSTGRES_PASSWORD=replace-with-DIFFERENT-token_urlsafe-32-output
TEST_POSTGRES_DB=outrider_test
TEST_POSTGRES_PORT=5433
TEST_DATABASE_URL=postgresql+psycopg://outrider:replace-with-DIFFERENT-token_urlsafe-32-output@127.0.0.1:5433/outrider_test

# ── GitHub App (read by GitHubAppSettings, env_prefix="OUTRIDER_GITHUB_") ───
# `GitHubAppSettings` (src/outrider/github/config.py) is frozen + extra="forbid".
# A typo or unprefixed name (e.g., `GITHUB_APP_ID`) raises ValidationError at
# lifespan startup, not a silent fallback. Keep the `OUTRIDER_GITHUB_` prefix.
OUTRIDER_GITHUB_APP_ID=123456
OUTRIDER_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
OUTRIDER_GITHUB_WEBHOOK_SECRET=replace-me

# ── Slack notifications (DEV/LOCAL bootstrap, read by SlackSettings) ─────────
# DEV/LOCAL ONLY. `SlackSettings` (src/outrider/notify/config.py) is a
# single-workspace env bootstrap to wire + test the notifier before the OAuth
# install path lands. The PRODUCTION V1 config authority is per-installation
# storage (the `installations` table, populated by the OAuth oauth.v2.access
# exchange) per specs/2026-06-15-slack-dashboard-in-slack.md — this env path is
# NOT the production posting authority. frozen + extra="forbid"; the bot token
# is empty/placeholder-rejected at startup (the xoxb- shape itself isn't enforced —
# a wrong token fails at the first Slack post). Optional — leave commented unless
# you're testing Slack notifications locally.
# OUTRIDER_SLACK_BOT_TOKEN=xoxb-your-token
# OUTRIDER_SLACK_CHANNEL_ID=C0123ABC

# ── Slack OAuth + per-install token storage (PRODUCTION install flow) ─────────
# The production V1 Slack config authority. An admin connects each GitHub App
# install to a Slack workspace via GET /slack/install (admin-authed) → Slack
# authorize → GET /slack/oauth/callback, which exchanges the code for a bot token,
# encrypts it (DECISIONS.md#051), and stores it per-install on the installations
# table. All five vars below are required for the OAuth install flow; leave them
# unset to disable it (the dev bootstrap above is the only other Slack path).
#
#   OUTRIDER_TOKEN_ENC_KEY       — Fernet key (urlsafe-base64, 32 bytes) encrypting
#                                  the per-install bot token at rest. Comma-separated
#                                  for MultiFernet rotation (first encrypts, all
#                                  decrypt). Generate: python -c "from cryptography
#                                  .fernet import Fernet; print(Fernet.generate_key()
#                                  .decode())". Fail-closed on a non-Fernet value.
#   OUTRIDER_SLACK_STATE_SECRET  — random secret signing the OAuth `state` CSRF token
#                                  (HMAC-SHA256); a known placeholder is rejected.
#                                  Generate: python -c "import secrets; print(secrets
#                                  .token_urlsafe(32))".
#   OUTRIDER_SLACK_CLIENT_ID     — the Slack App client id (e.g. 123.456).
#   OUTRIDER_SLACK_CLIENT_SECRET — the Slack App client secret (placeholder rejected).
#   OUTRIDER_SLACK_REDIRECT_URI  — the OAuth callback URL; must match the redirect URL
#                                  registered in the Slack App config exactly.
# OUTRIDER_TOKEN_ENC_KEY=replace-me
# OUTRIDER_SLACK_STATE_SECRET=replace-me-with-a-long-random-secret
# OUTRIDER_SLACK_CLIENT_ID=123.456
# OUTRIDER_SLACK_CLIENT_SECRET=your-secret-here
# OUTRIDER_SLACK_REDIRECT_URI=https://outrider.example.com/slack/oauth/callback

# ── LLM provider ────────────────────────────────────────────────────────────
# The Anthropic SDK reads `ANTHROPIC_API_KEY` directly (vendor convention,
# no Outrider prefix). `ModelConfig` (env_prefix="OUTRIDER_MODEL_") reads
# per-tier model strings; defaults match the canonical spec, override via
# OUTRIDER_MODEL_TRIAGE_MODEL / OUTRIDER_MODEL_ANALYZE_MODEL if needed.
ANTHROPIC_API_KEY=replace-me
# Operator attestation that your Anthropic organization has a zero-data-retention
# arrangement in place. ZDR is enabled at the Anthropic-org level via contract
# (contact Anthropic sales) — Outrider does not enable ZDR by setting this flag.
# When false/unset, the AnthropicProvider emits a privacy-notice startup log
# stating Anthropic's standard 30-day retention applies. When true, Outrider
# treats the operator's claim of ZDR as attested and adjusts the user-facing
# privacy statement accordingly. See DECISIONS.md#015-zdr-is-an-operator-attestation-not-a-runtime-opt-in.
ANTHROPIC_ZDR_ENABLED=false

# ── LLM provider mode 2: GLM 5.2 via Baseten (OpenAI-compatible) — LIVE ──────
# Run the WHOLE pipeline on GLM-5.2 via Baseten instead of Anthropic (never mixed
# per-node in V1). The lifespan provider factory (DECISIONS.md#056) selects the
# host from OUTRIDER_LLM_HOST below and constructs OpenAICompatibleProvider bound
# to BASETEN_PROFILE, passing BASETEN_API_KEY to
# AsyncOpenAI(base_url="https://inference.baseten.co/v1"), model zai-org/GLM-5.2.
# BASETEN_API_KEY=replace-me
# ── LLM provider mode 3: GLM 5.2 via Fireworks (OpenAI-compatible, STRICT JSON) ──
# Same whole-pipeline swap as Baseten, but Fireworks' strict json_schema is honored
# on the raw analyze schema (DECISIONS.md#056 amendment 2026-07-06), pricing is
# $1.40/$0.14/$4.40 per MTok (Standard), and reasoning-off is reasoning_effort="none".
# The factory selects FIREWORKS_PROFILE, model accounts/fireworks/models/glm-5p2,
# base_url https://api.fireworks.ai/inference/v1.
# FIREWORKS_API_KEY=replace-me
# Host selector — read ONCE by the lifespan factory; default `anthropic`. Set to
# `baseten` or `fireworks` to run the whole pipeline on GLM-5.2 (fails loud at
# startup if the selected host's api key env is unset). Adding DeepInfra = a
# HostProfile + a RATE_TABLE row (arc 2), then point this at that host id.
# OUTRIDER_LLM_HOST=baseten
# Reasoning toggle, default off. V1 has no verified reasoning-ON wire for an
# OpenAI-compatible host, so `true` on an off-switch host fails closed at startup.
# OUTRIDER_LLM_REASONING=false

# ── Operator config knobs ───────────────────────────────────────────────────
# A mix of (a) live-in-V1 settings the lifespan / nodes actually read, and
# (b) forward-compat shape pins for surfaces that haven't shipped. Each
# entry below names its current consumer status. Setting (b) entries today
# is a no-op; setting (a) entries is required for app startup or affects
# runtime behavior:
#
#   OUTRIDER_ADMIN_API_KEY      — dashboard bearer-token auth. REQUIRED at
#                                  lifespan startup (DashboardSettings reads
#                                  this via pydantic-settings); missing or
#                                  empty causes the FastAPI app to refuse
#                                  startup with a ValidationError. Consumed
#                                  by `POST /reviews/{id}/decide` per
#                                  api/dashboard/auth.py.
#   OUTRIDER_AGENT_API_KEY      — OPTIONAL read-only token for the agent-view
#                                  endpoint (feature 3 / S2,
#                                  GET /reviews/{id}/agent-view). SEPARATE scope
#                                  from the admin key — agents must NOT hold the
#                                  admin key (it can POST /decide). Unset => the
#                                  agent surface is disabled (uniform 401).
#                                  Consumed by
#                                  api/dashboard/auth.py::require_agent_api_key.
#   OUTRIDER_DASHBOARD_BASE_URL — OPTIONAL public base URL of the Outrider
#                                  dashboard (e.g. https://outrider.example.com).
#                                  When set, publish embeds per-finding + aggregate
#                                  deep-links in the review body (DECISIONS.md#050);
#                                  unset => the review body renders the no-link
#                                  fallback. Validated at render time
#                                  (publish.py::_is_markdown_link_safe_url) — a
#                                  malformed value degrades to no-link, never a
#                                  broken link.
#   PER_REVIEW_BUDGET_USD       — NOT wired (legacy/aspirational). The live
#                                  per-review cost ceiling is a TOKEN budget, now
#                                  tunable via OUTRIDER_ANALYZE_REVIEW_BUDGET_TOKENS
#                                  (read by AnalyzeConfig,
#                                  agent/nodes/analyze_config.py; default
#                                  DEFAULT_REVIEW_BUDGET_TOKENS=200000 in
#                                  src/outrider/agent/nodes/analyze.py) — see below.
#   MAX_DIFF_LINES_DEEP/STANDARD,
#   MAX_CHANGED_FILES           — NOT wired (legacy). The intake whole-PR size
#                                  gate is now OUTRIDER_INTAKE_MAX_FILES /
#                                  OUTRIDER_INTAKE_MAX_LINES (read by IntakeConfig,
#                                  agent/nodes/intake_config.py) — see below.
#   MAX_TRACE_DEPTH             — trace ⇄ analyze loop depth (trace shipped
#                                  2026-05-24 as `MAX_ANALYSIS_ROUNDS=2` in
#                                  src/outrider/agent/nodes/trace.py; this env
#                                  var is NOT currently read — see FUP for
#                                  tunable trace-side settings)
#   MAX_FINDINGS_PER_REVIEW     — synthesize-side cap (synthesize not shipped)
#   OUTRIDER_HITL_TIMEOUT_MINUTES,
#   OUTRIDER_HITL_TIMEOUT_ACTION — hitl gate (read by HITLConfig per
#                                  agent/nodes/hitl_config.py; default
#                                  `expire_only`; `auto_post` rejected at
#                                  startup until V1.5)
#   OUTRIDER_SWEEP_DISABLED     — set to "1" to disable the in-process
#                                  asyncio sweep loop in api/lifespan.py
#                                  + api/lifespan_sweep_loop.py. Use this
#                                  if you're running the sweep via an
#                                  external scheduler (cron, k8s CronJob,
#                                  APScheduler) and don't want two
#                                  invokers racing for SWEEP_LOCK_ID.
#                                  The lifespan loop fires every 5min
#                                  per docs/spec.md §4.1.6. Reading
#                                  is in src/outrider/api/lifespan.py.
OUTRIDER_ADMIN_API_KEY=replace-me
# OPTIONAL — uncomment + set a real secret to enable GET /reviews/{id}/agent-view
# (feature 3 / S2). Leave unset to disable that surface.
# OUTRIDER_AGENT_API_KEY=replace-me
PER_REVIEW_BUDGET_USD=0.30
MAX_DIFF_LINES_DEEP=500
MAX_DIFF_LINES_STANDARD=1000
MAX_CHANGED_FILES=30
MAX_TRACE_DEPTH=2
MAX_FINDINGS_PER_REVIEW=25
# Intake whole-PR size gate (docs/spec.md §6.10) — THESE are wired (IntakeConfig).
# Skip a PR with > MAX_LINES changed lines OR > MAX_FILES files. Defaults 1000 / 30;
# raise to review bigger PRs. MAX_FILES is capped at 99 (the gate uses one
# GET /pulls/{n}/files call and GitHub caps per_page at 100).
OUTRIDER_INTAKE_MAX_LINES=1000
OUTRIDER_INTAKE_MAX_FILES=30
# Per-review analyze token budget (specs/2026-06-17-analyze-cost-fairness.md Stage 0)
# — WIRED (AnalyzeConfig). The analyze node spends at most this many estimated tokens
# across all DEEP/STANDARD files in one review; files past the ceiling skip with
# COST_BUDGET_EXHAUSTED. Default 200000. Raise it to review bigger PRs. The legacy
# PER_REVIEW_BUDGET_USD above is not read by any code.
OUTRIDER_ANALYZE_REVIEW_BUDGET_TOKENS=200000
# Max concurrently-running analyze workers per (compiled graph, event loop)
# — the parallel fan-out's in-flight bound (default 4). On the single-loop
# production server this caps concurrent per-file LLM calls across all
# in-flight reviews.
OUTRIDER_ANALYZE_MAX_CONCURRENCY=4
# Suggested patches (feature 2 / DECISIONS.md#040 — read by PatchConfig + ModelConfig).
# Synthesize generates a GitHub ```suggestion block for HIGH/CRITICAL single-line
# findings; publish renders it on INLINE_COMMENT findings. PATCHES_ENABLED=false skips
# the pass entirely (zero added cost). Patch-gen uses Haiku (cost; never Sonnet).
OUTRIDER_PATCHES_ENABLED=true
OUTRIDER_MAX_PATCH_SUGGESTIONS_PER_REVIEW=5
OUTRIDER_MODEL_PATCH_MODEL=claude-haiku-4-5
# Analyze tiered model routing (DECISIONS.md#041): DEEP-tier files use
# OUTRIDER_MODEL_ANALYZE_MODEL (Sonnet); STANDARD-tier files use this. Defaults to Haiku
# (the eval-gated cost flip, 3x cheaper at the same tokens) — leave unset to take that
# default. Uncomment the line below to ROLL BACK STANDARD-tier analyze to Sonnet.
# OUTRIDER_MODEL_STANDARD_ANALYZE_MODEL=claude-sonnet-4-6
OUTRIDER_HITL_TIMEOUT_MINUTES=30
OUTRIDER_HITL_TIMEOUT_ACTION=expire_only
# OUTRIDER_SWEEP_DISABLED=1  # uncomment to disable the in-process sweep loop
# Concurrent-review ceiling (FUP-164 / DECISIONS.md#045 — read by DispatchConfig
# per dispatcher/config.py). Bounds how many graph executions run at once so a
# webhook flood can't saturate the 50-connection Anthropic pool. Default 8.
# Per-process bound: real ceiling under N workers is N x this value. Min 1.
# OUTRIDER_MAX_CONCURRENT_REVIEWS=8

# Audit content retention
# TTL for llm_call_content rows (default 90 days per DECISIONS.md#016).
# Override format: ISO-8601 duration string (P7D, PT24H, PT3600S). Bare
# integer seconds are NOT accepted by pydantic-settings 2.13. Zero or
# negative values are rejected at startup via the gt=timedelta(0) validator.
# Leave commented to use the 90-day default.
# OUTRIDER_AUDIT_LLM_CONTENT_RETENTION_TTL=P90D

# Output sanitizer — HMAC-tagged truncation marker secret per
# `src/outrider/policy/output_sanitizer.py`. The publish-side sanitizer
# embeds an 8-char HMAC keyed by this secret into truncation markers so
# attacker-controlled content can't forge the marker shape and confuse
# `strip_fake_truncation_markers`. REQUIRED — validated at app startup (the lifespan
# fails loud if unset/empty) AND the sanitizer raises RuntimeError at use time; there
# is NO development fallback. Uncommented so `cp .env.example .env` boots; override in
# production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
OUTRIDER_TRUNCATION_HMAC_SECRET=replace-me-with-a-long-random-secret

# Logging
LOG_LEVEL=info
